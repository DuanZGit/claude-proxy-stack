# Headroom proxy configuration
# Copy this file to config/headroom.env and fill in your values

# Agnes-ai API Key (required)
OPENAI_API_KEY="sk-YOUR-AGNES-API-KEY-HERE"

# Headroom settings
HEADROOM_PORT=8787
HEADROOM_MODE=cache
HEADROOM_TELEMETRY=off

# Upstream API URL (optional, defaults to agnes-ai hub)
# AGNES_API_URL=https://apihub.agnes-ai.com
